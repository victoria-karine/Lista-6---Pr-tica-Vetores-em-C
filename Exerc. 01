
#include <stdio.h>

int main() {
    
    int numeros [10];
    int pos;
  //LEia os 10 numeros
for (pos = 0; pos < 10; pos++) {
  printf("Digite o nº da posição %d\n", pos);
  scanf ("%d", &numeros[pos]);
  
  
  for (pos = 0; pos < 10; pos++) {
  if (numeros[pos] < 10) {
    continue; // pular números negativos
  }
  if (numeros[pos] == 0) {
    break; //parar o loop quando encontra 0
  }
  printf("%d\n", numeros[pos]);
}
    //Exiba os 10 numeros

    return 0;
}}
